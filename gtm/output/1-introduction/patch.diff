diff --git a/baml_src/clients.baml b/baml_src/clients.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/clients.baml
@@ -0,0 +1,23 @@
+client<llm> DefaultOpenAI {
+  provider openai
+  options {
+    model "gpt-4o-mini"
+    api_key env.OPENAI_API_KEY
+  }
+}
+
+client<llm> DefaultAnthropic {
+  provider anthropic
+  options {
+    model "claude-3-5-sonnet-20241022"
+    api_key env.ANTHROPIC_API_KEY
+  }
+}
+
+client<llm> DefaultGemini {
+  provider google-ai
+  options {
+    model "gemini-2.5-flash"
+    api_key env.GEMINI_API_KEY
+  }
+}
diff --git a/baml_src/extractcalendarevent.baml b/baml_src/extractcalendarevent.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/extractcalendarevent.baml
@@ -0,0 +1,23 @@
+class CalendarEvent {
+  name string
+  date string
+  participants string[]
+}
+
+function ExtractCalendarEvent(user_message: string) -> CalendarEvent {
+  client "openai/gpt-4o"
+  prompt #"
+    Extract the event information.
+
+    User: {{ user_message }}
+
+    {{ ctx.output_format }}
+  "#
+}
+
+test science_fair {
+  functions [ExtractCalendarEvent]
+  args {
+    user_message "Alice and Bob are going to a science fair on Friday."
+  }
+}
