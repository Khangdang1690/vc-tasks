diff --git a/baml_src/retrieveknowledgebaseanswer.baml b/baml_src/retrieveknowledgebaseanswer.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/retrieveknowledgebaseanswer.baml
@@ -0,0 +1,16 @@
+class KBResponse {
+  answer string
+  source int
+}
+
+function RetrieveKnowledgeBaseAnswer(question: string) -> KBResponse {
+  client "openai/gpt-4o"
+  prompt #"
+    Answer the following question based on your knowledge.
+    Provide the answer and the record ID of the source.
+
+    Question: {{ question }}
+
+    {{ ctx.output_format }}
+  "#
+}
diff --git a/baml_src/writelimerick.baml b/baml_src/writelimerick.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/writelimerick.baml
@@ -0,0 +1,16 @@
+function WriteLimerick(topic: string) -> string {
+  client "openai/gpt-4o"
+  prompt #"
+    You're a helpful assistant.
+    Write a limerick about the {{ topic }} programming language.
+
+    {{ ctx.output_format }}
+  "#
+}
+
+test python_limerick {
+  functions [WriteLimerick]
+  args {
+    topic "Python"
+  }
+}
