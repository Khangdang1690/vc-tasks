+++ b/baml_src/generateeventconfirmation.baml
@@ -0,0 +1,31 @@
+class EventConfirmation {
+  confirmation_message string
+  calendar_link string?
+}
+
+function GenerateEventConfirmation(event_details_json: string) -> EventConfirmation {
+  client "openai/gpt-4o-mini"
+  prompt #"
+    Generate a natural confirmation message for the event. Sign off with your name; Susie.
+
+    Event Details:
+    {{ event_details_json }}
+
+    {{ ctx.output_format }}
+  "#
+}
+
+test sample_event_confirmation {
+  functions [GenerateEventConfirmation]
+  args {
+    event_details_json #"
+      {
+        \"title\": \"Project Kickoff\",
+        \"date\": \"2024-11-15\",
+        \"time\": \"14:00\",
+        \"location\": \"Conference Room A\",
+        \"attendees\": [\"John Doe\", \"Jane Smith\"]
+      }
+    "#
+  }
+}
diff --git a/baml_src/generatesectioncontent.baml b/baml_src/generatesectioncontent.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/generatesectioncontent.baml
@@ -0,0 +1,22 @@
+class SectionContent {
+  content string
+  key_points string[]
+}
+
+function GenerateSectionContent(topic: string, section_type: string, description: string, style_guide: string, target_length: string, previous_sections: string) -> SectionContent {
+  client "openai/gpt-4o-mini"
+  prompt #"
+    You are a helpful assistant writing a section for a document.
+
+    Topic: {{ topic }}
+    Section Type: {{ section_type }}
+    Description: {{ description }}
+    Style Guide: {{ style_guide }}
+    Target Length: {{ target_length }}
+    Previous Sections: {{ previous_sections }}
+
+    Please write the content for this section and identify the main points covered.
+
+    {{ ctx.output_format }}
+  "#
+}
