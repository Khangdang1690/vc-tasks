diff --git a/baml_src/getorchestratorplan.baml b/baml_src/getorchestratorplan.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/getorchestratorplan.baml
@@ -0,0 +1,24 @@
+class SubTask {
+  title string
+  description string
+}
+
+class OrchestratorPlan {
+  topic_analysis string
+  target_audience string
+  sections SubTask[]
+}
+
+function GetOrchestratorPlan(topic: string, target_length: int, style: string) -> OrchestratorPlan {
+  client "openai/gpt-4o-mini"
+  prompt #"
+    You are an expert blog post orchestrator. Your task is to create a detailed plan for a blog post.
+    The blog post should be about: {{ topic }}
+    It should aim for a target length of approximately {{ target_length }} words.
+    The writing style should be: {{ style }}
+
+    Provide a comprehensive plan including an analysis of the topic, the target audience, and a list of sections with their titles and descriptions.
+
+    {{ ctx.output_format }}
+  "#
+}
diff --git a/baml_src/parseeventdetails.baml b/baml_src/parseeventdetails.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/parseeventdetails.baml
@@ -0,0 +1,17 @@
+class EventDetails {
+  name string @description("Name of the event")
+  date string @description("Date and time of the event. Use ISO 8601 to format this value.")
+  duration_minutes int @description("Expected duration in minutes")
+  participants string[] @description("List of participants")
+}
+
+function ParseEventDetails(dateContext: string, description: string) -> EventDetails {
+  client "openai/gpt-4o-mini"
+  prompt #"
+    {{ dateContext }} Extract detailed event information. When dates reference 'next Tuesday' or similar relative dates, use this current date as reference.
+
+    User: {{ description }}
+
+    {{ ctx.output_format }}
+  "#
+}
diff --git a/baml_src/reviewblogcontent.baml b/baml_src/reviewblogcontent.baml
new file mode 100644
--- /dev/null
+++ b/baml_src/reviewblogcontent.baml
@@ -0,0 +1,25 @@
+class SuggestedEdits {
+  section_name string
+  edits string[]
+}
+
+class ReviewFeedback {
+  cohesion_score float
+  suggested_edits SuggestedEdits[]
+  final_version string
+}
+
+function ReviewBlogContent(topic: string, audience: string, sections: string) -> ReviewFeedback {
+  client "openai/gpt-4o-mini"
+  prompt #"
+    You are an expert blog post reviewer. Your task is to provide a comprehensive review and suggestions for a blog post based on its topic, target audience, and content sections.
+
+    Topic: {{ topic }}
+    Target Audience: {{ audience }}
+    Sections:
+    {{ sections }}
+
+    Please provide a cohesion score (0-1), suggested edits for each section, and a final polished version of the blog post.
+    {{ ctx.output_format }}
+  "#
+}
